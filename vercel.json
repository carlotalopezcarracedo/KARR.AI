{
  "$schema": "https://openapi.vercel.sh/vercel.json",
  "headers": [
    {
      "source": "/assets/(.*)",
      "headers": [
        {
          "key": "Cache-Control",
          "value": "public, max-age=31556952, immutable"
        }
      ]
    },
    {
      "source": "/:path*.(png|jpg|jpeg|gif|webp|svg|ico|avif)",
      "headers": [
        {
          "key": "Cache-Control",
          "value": "public, max-age=31556952, immutable"
        }
      ]
    }
  ],
  "redirects": [
    {
      "source": "/automatizacion-seguimiento-clientes",
      "destination": "/crm-pymes-seguimiento-clientes/",
      "permanent": true
    },
    {
      "source": "/automatizacion-seguimiento-clientes/",
      "destination": "/crm-pymes-seguimiento-clientes/",
      "permanent": true
    },
    {
      "source": "/automatizacion-procesos-empresas",
      "destination": "/automatizacion-procesos/",
      "permanent": true
    },
    {
      "source": "/automatizacion-procesos-empresas/",
      "destination": "/automatizacion-procesos/",
      "permanent": true
    },
    {
      "source": "/automatizacion-ia-empresas-galicia",
      "destination": "/automatizacion-empresas-galicia/",
      "permanent": true
    },
    {
      "source": "/automatizacion-ia-empresas-galicia/",
      "destination": "/automatizacion-empresas-galicia/",
      "permanent": true
    },
    {
      "source": "/accesibilidad.html",
      "destination": "/accesibilidad/",
      "permanent": true
    },
    {
      "source": "/aviso-legal.html",
      "destination": "/aviso-legal/",
      "permanent": true
    },
    {
      "source": "/cookies.html",
      "destination": "/cookies/",
      "permanent": true
    },
    {
      "source": "/privacidad.html",
      "destination": "/privacidad/",
      "permanent": true
    }
  ]
}
